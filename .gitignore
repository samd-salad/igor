# Python
__pycache__/
*.py[cod]
*.so
venv/
.venv/

# Local data (contains personal info, network config, logs)
data/*.txt
data/*.json
data/*.jsonl
data/*.csv
data/*.log
data/*.yaml
data/*.migrated
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# Claude Code local settings
.claude/

# Audio files (recordings, samples)
*.wav

# Trained wake word models (personal voice data, large binaries)
wakeword/models/*.onnx
wakeword/models/*.tflite
wakeword/models/*_tflite_out/

# Wake word samples (personal voice recordings)
wakeword/samples/positive/*.wav
wakeword/samples/negative/*.wav

# Speaker embeddings (biometric voice data)
data/speaker_embeddings.json

# Google TV pairing certs (private key material)
data/google_tv_cert.pem
data/google_tv_key.pem

# ADB RSA key pair (grants shell access to TV)
data/adbkey
data/adbkey.pub

# Local onnx2tf conversion venv (used for TFLite export)
.onnx2tf-venv/

# Wakeword training venv (Py 3.12, contains torch/tf/onnx2tf — large)
.venv-wake/

# Wakeword training scratch (log + intermediate TF outputs)
wakeword/_train.log
wakeword/_tf_out/
wakeword/models/igor_fixed_batch.onnx

# Piper TTS voices (downloaded; regenerate as needed)
wakeword/piper_voices/

# Piper-generated synthetic positive samples (regenerate via synthesize_positives.py)
wakeword/samples/positive_synth/

# Environment files (may contain API keys)
.env
.env.*

# IDE
.vscode/
.idea/
