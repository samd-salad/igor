# Room configuration for Igor multi-client support.
# Copy to data/rooms.yaml and edit for your setup.
# If rooms.yaml doesn't exist, Igor synthesizes one room per HA Area at startup.
#
# In the HA-backed era, the only required field is `ha_area` — that's what
# scopes the device commands (lights, media players, TVs) to the room. The
# legacy fields (sonos_zone, tv_host, light_group, indicator_light) are
# ignored by the HA-backed commands and will be removed entirely once the
# old audio code is deleted.

rooms:
  living_room:
    display_name: "Living Room"
    ha_area: "Living Room"        # Must match an HA Area name exactly (case-insensitive)

  office:
    display_name: "Office"
    ha_area: "Office"

  bedroom:
    display_name: "Bedroom"
    ha_area: "Bedroom"

  phone:
    display_name: "Phone"
    ha_area: "Living Room"        # Phone falls back to living-room scope for ambient commands
    text_only: true               # No audio I/O — text endpoint only
