# Keep the Docker build context small and the image free of audio/wakeword
# artifacts that the text-only server doesn't need.

.git
.github
.venv
__pycache__
**/__pycache__
*.pyc
*.pyo
*.pyd

# Local user data — never bake into image
data/*.json
data/*.jsonl
data/*.csv
data/*.log
data/*.migrated
data/*.pem
data/adbkey*
data/beep_*.wav
data/rooms.yaml
data/speaker_embeddings.json

# Wakeword training artifacts — not needed in the server container
wakeword/
Screenshot*.png

# Dev/editor cruft
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# HA integration lives in a user's HA config, not in the container
custom_components/

# Docs/plans
CLAUDE.md
MEMORY_ROADMAP.md
